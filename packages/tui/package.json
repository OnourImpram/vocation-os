{
  "name": "@vocation-os/tui",
  "version": "0.6.1",
  "description": "Pure queue view models and an Ink-compatible daemon client boundary for VocationOS.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./entry": {
      "types": "./dist/entry.d.ts",
      "import": "./dist/entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "ink": "7.1.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17"
  }
}
