{
  "name": "@vocation-os/mcp",
  "version": "0.6.0",
  "description": "Read-first MCP tool contracts with enforced capability and approval gates for VocationOS.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "bin": {
    "vocation-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "import": "./dist/backend.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    },
    "./transport": {
      "types": "./dist/cli-transport.d.ts",
      "import": "./dist/cli-transport.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "pretest": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "peerDependencies": {
    "@vocation-os/sdk": "0.2.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
