{
  "name": "@vocation-os/workbench",
  "version": "0.6.1",
  "description": "Secure loopback client contracts and route view models for the VocationOS workbench.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./entry": {
      "types": "./dist/entry.d.ts",
      "import": "./dist/entry.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css",
    "public",
    "index.html"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm run build:library && npm run build:app",
    "build:library": "tsc -p tsconfig.json",
    "build:app": "vite build",
    "dev": "vite --host 127.0.0.1",
    "mock:daemon": "node test/mock-loopback-server.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "vite": "8.1.5"
  }
}
