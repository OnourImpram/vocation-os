{
  "name": "vocation-os",
  "version": "0.5.0",
  "description": "Evidence grounded career decision safety for high agency operators.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "bundleDependencies": [
    "@vocation-os/sdk"
  ],
  "bin": {
    "vocation": "./dist/cli.js",
    "vocationd": "./dist/vocationd.js"
  },
  "files": [
    "dist",
    "assets/fonts",
    "schemas",
    "examples",
    "docs",
    "README.md",
    "CITATION.cff",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "DIFFERENTIATION_REPORT.md",
    "GOVERNANCE.md",
    "LICENSE",
    "PRIVACY.md",
    "SAFETY.md",
    "SECURITY.md"
  ],
  "keywords": [
    "vocation-os",
    "vocational-psychology",
    "career-guidance",
    "decision-support",
    "ai-safety",
    "human-in-the-loop",
    "llm-agent",
    "typescript",
    "cli",
    "reversibility",
    "evidence-based",
    "career-development"
  ],
  "scripts": {
    "build:sdk": "npm run build --workspace @vocation-os/sdk",
    "build": "npm run build:sdk && node scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "typecheck": "npm run typecheck --workspace @vocation-os/sdk && npm run build:sdk && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:cli": "npm run build && node scripts/cli-subprocess-smoke.mjs",
    "validate:schemas": "tsx src/cli.ts validate-schemas",
    "privacy:scan": "node scripts/privacy-scan.mjs",
    "brand:scan": "node scripts/brand-scan.mjs",
    "docs:check": "node scripts/docs-check.mjs",
    "docs:theory-map": "tsx scripts/theory-map.ts",
    "citations:check": "node scripts/citation-check.mjs",
    "citations:check:online": "node scripts/citation-check-online.mjs",
    "sbom:check": "node scripts/sbom-check.mjs",
    "selfcheck": "tsx src/cli.ts selfcheck",
    "evaluate": "tsx src/cli.ts evaluate",
    "scan-fable": "node scripts/scan-fable.mjs",
    "site:dev": "astro dev --host 127.0.0.1",
    "site:build": "astro build",
    "site:preview": "astro preview",
    "pack:check": "npm run build && node scripts/pack-check.mjs",
    "ci": "npm run privacy:scan && npm run brand:scan && npm run typecheck && npm run coverage && npm run validate:schemas && npm run selfcheck && npm run evaluate && npm run scan-fable && npm run docs:check && npm run citations:check && npm run sbom:check && npm run site:build && npm run test:cli && npm run pack:check",
    "safe:publish-check": "npm run ci"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "1.1.1",
    "@vocation-os/sdk": "0.2.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.11.1",
    "docx": "9.7.1",
    "kysely": "^0.29.3",
    "mammoth": "1.12.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "6.1.200"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "4.1.10",
    "astro": "^7.0.6",
    "jszip": "3.10.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "4.1.10"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.3.0"
  }
}
