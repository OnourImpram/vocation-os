{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/intelligence-interview.schema.json",
  "title": "InterviewIntelligenceResult",
  "oneOf": [
    { "$ref": "#/definitions/storyValidation" },
    { "$ref": "#/definitions/mockEvaluation" }
  ],
  "definitions": {
    "evidenceRefs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "assertions": { "type": "array", "minItems": 1, "items": { "$ref": "https://vocation-os.dev/schemas/intelligence-assertion.schema.json" } },
    "storyValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storyId", "valid", "reasonCodes", "missingSegments", "invalidClaimIds", "evidenceRefs", "assertions"],
      "properties": {
        "storyId": { "type": "string", "minLength": 1 },
        "valid": { "type": "boolean" },
        "reasonCodes": { "type": "array", "uniqueItems": true, "items": { "enum": ["graph-invalid", "competency-missing", "segment-missing", "claim-missing", "claim-unverified", "claim-private"] } },
        "missingSegments": { "type": "array", "uniqueItems": true, "items": { "enum": ["situation", "task", "action", "result"] } },
        "invalidClaimIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "evidenceRefs": { "$ref": "#/definitions/evidenceRefs" },
        "assertions": { "$ref": "#/definitions/assertions" }
      }
    },
    "mockEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observationId", "storyId", "status", "reviewBand", "segmentCoverage", "claimCoverage", "meanCriterionRating", "evidenceRefs", "assertions"],
      "properties": {
        "observationId": { "type": "string", "minLength": 1 },
        "storyId": { "type": "string", "minLength": 1 },
        "status": { "enum": ["invalid-story", "review-required"] },
        "reviewBand": { "enum": ["evidence-gap", "complete-structure"] },
        "segmentCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "claimCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "meanCriterionRating": { "oneOf": [{ "type": "number", "minimum": 0, "maximum": 4 }, { "type": "null" }] },
        "evidenceRefs": { "$ref": "#/definitions/evidenceRefs" },
        "assertions": { "$ref": "#/definitions/assertions" }
      }
    }
  }
}
