{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/opportunity-intake.schema.json",
  "title": "OpportunityIntakeDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["opportunityId", "status", "reasons", "gates", "evaluatedAt"],
  "properties": {
    "opportunityId": {
      "type": "string",
      "pattern": "^OPP-[A-Z0-9-]+$"
    },
    "status": {
      "type": "string",
      "enum": ["accepted", "manual_review", "rejected"]
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate", "outcome", "reason"],
        "properties": {
          "gate": { "type": "string", "minLength": 1 },
          "outcome": {
            "type": "string",
            "enum": ["pass", "manual-review", "reject"]
          },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}

