{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/coaching-plan.schema.json",
  "title": "CoachingPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planId",
    "mode",
    "reversibilityTag",
    "generatedAt",
    "disclaimer",
    "focusSkills",
    "practices",
    "journalPrompts",
    "sourceTheories"
  ],
  "properties": {
    "planId": {
      "type": "string",
      "pattern": "^CP-[A-Za-z0-9-]+$"
    },
    "mode": {
      "type": "string",
      "const": "/skill-coach"
    },
    "reversibilityTag": {
      "type": "string",
      "const": "R0"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    },
    "focusSkills": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["curiosity", "persistence", "flexibility", "optimism", "risk-taking"]
      },
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true
    },
    "practices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "actProcess", "microPractice", "reflectionPrompt", "reversibilityTag"],
        "properties": {
          "skill": {
            "type": "string",
            "enum": ["curiosity", "persistence", "flexibility", "optimism", "risk-taking"]
          },
          "actProcess": {
            "type": "string",
            "minLength": 1
          },
          "microPractice": {
            "type": "string",
            "minLength": 1
          },
          "reflectionPrompt": {
            "type": "string",
            "minLength": 1
          },
          "reversibilityTag": {
            "type": "string",
            "const": "R0"
          }
        }
      }
    },
    "journalPrompts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "sourceTheories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "referralNote": {
      "type": "string",
      "minLength": 1
    }
  }
}

