{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/discovery-liveness-assessment.schema.json",
  "title": "LivenessAssessment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "assessmentId",
    "sourceKey",
    "state",
    "confidence",
    "assessedAt",
    "evidenceObservationIds",
    "reasons"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "assessmentId": { "type": "string", "pattern": "^LIVE-[A-F0-9]{32}$" },
    "sourceKey": {
      "oneOf": [
        { "type": "string", "minLength": 1, "maxLength": 512 },
        { "type": "null" }
      ]
    },
    "state": { "enum": ["live", "closed", "stale", "unreachable", "unresolved"] },
    "confidence": { "enum": ["high", "medium", "low"] },
    "assessedAt": { "type": "string", "format": "date-time" },
    "evidenceObservationIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^OBS-[A-F0-9]{32}$" }
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 1024 }
    }
  }
}
