{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/credential-mapping.schema.json",
  "title": "CredentialClaimMapping",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mappingId",
    "credentialId",
    "credentialHash",
    "claimType",
    "claimText",
    "sourcePointer",
    "requestedPublic",
    "requestedAutoApply",
    "publiclyAssertable",
    "allowedInAutoApply",
    "status",
    "mappingHash",
    "approval"
  ],
  "properties": {
    "mappingId": { "$ref": "#/definitions/identifier" },
    "credentialId": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "credentialHash": { "$ref": "#/definitions/hash" },
    "claimType": {
      "enum": [
        "degree",
        "license",
        "publication",
        "affiliation",
        "grant",
        "employment",
        "credential",
        "award",
        "skill",
        "project",
        "other"
      ]
    },
    "claimText": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "sourcePointer": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "requestedPublic": { "type": "boolean" },
    "requestedAutoApply": { "type": "boolean" },
    "publiclyAssertable": { "type": "boolean" },
    "allowedInAutoApply": { "type": "boolean" },
    "status": { "enum": ["pending", "approved"] },
    "mappingHash": { "$ref": "#/definitions/hash" },
    "approval": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/definitions/mappingApproval" }
      ]
    }
  },
  "definitions": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "not": { "enum": ["__proto__", "constructor", "prototype"] }
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "mappingApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approvalId",
        "approverPrincipalId",
        "approvedAt",
        "expiresAt",
        "mappingHash",
        "allowPublic",
        "allowAutoApply",
        "signatureReceiptHash"
      ],
      "properties": {
        "approvalId": { "$ref": "#/definitions/identifier" },
        "approverPrincipalId": { "$ref": "#/definitions/identifier" },
        "approvedAt": { "$ref": "#/definitions/dateTime" },
        "expiresAt": { "$ref": "#/definitions/dateTime" },
        "mappingHash": { "$ref": "#/definitions/hash" },
        "allowPublic": { "type": "boolean" },
        "allowAutoApply": { "type": "boolean" },
        "signatureReceiptHash": { "$ref": "#/definitions/hash" }
      }
    }
  }
}
