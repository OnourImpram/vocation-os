{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/discovery-signed-network-access-grant.schema.json",
  "title": "SignedNetworkAccessGrantEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grant",
    "approvedBy",
    "keyId",
    "signatureAlgorithm",
    "grantDigest",
    "signature"
  ],
  "properties": {
    "grant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grantId",
        "subject",
        "purpose",
        "providerId",
        "manifestId",
        "manifestVersion",
        "issuedAt",
        "expiresAt",
        "allowedHosts",
        "allowedMethods",
        "requestBudget"
      ],
      "properties": {
        "grantId": { "type": "string", "pattern": "^NAG-[A-Z0-9][A-Z0-9-]{7,127}$" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 160 },
        "purpose": { "type": "string", "minLength": 1, "maxLength": 512 },
        "providerId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
        "manifestId": { "type": "string", "pattern": "^egress:[a-z][a-z0-9-]{1,63}$" },
        "manifestVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "issuedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "allowedHosts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 3, "maxLength": 253 }
        },
        "allowedMethods": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "enum": ["GET", "HEAD"] }
        },
        "requestBudget": { "type": "integer", "minimum": 1, "maximum": 1000000 }
      }
    },
    "approvedBy": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$" },
    "keyId": { "type": "string", "pattern": "^KEY-[A-Za-z0-9-]{8,100}$" },
    "signatureAlgorithm": { "const": "Ed25519" },
    "grantDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "signature": {
      "type": "string",
      "minLength": 86,
      "maxLength": 86,
      "pattern": "^[A-Za-z0-9_-]+$"
    }
  }
}
