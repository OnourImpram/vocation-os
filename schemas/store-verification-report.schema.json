{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/store-verification-report.schema.json",
  "title": "StoreVerificationReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["valid", "eventCount", "head", "databaseId", "migrations"],
  "properties": {
    "valid": { "const": true },
    "eventCount": { "type": "integer", "minimum": 0 },
    "head": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventCount", "headHash"],
      "properties": {
        "eventCount": { "type": "integer", "minimum": 0 },
        "headHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "databaseId": { "type": "string", "pattern": "^DB-[0-9a-f-]{36}$" },
    "migrations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "name", "appliedAt", "checksum"],
        "properties": {
          "version": { "type": "integer", "minimum": 1 },
          "name": { "type": "string", "minLength": 1 },
          "appliedAt": { "type": "string", "format": "date-time" },
          "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    }
  }
}
