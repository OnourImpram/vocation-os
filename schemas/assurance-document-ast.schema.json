{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/assurance-document-ast.schema.json",
  "title": "AssuranceDocumentAstInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "documentId", "documentType", "title", "generatedAt", "metadata", "layout", "nodes"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "documentId": { "type": "string", "pattern": "^DOC-ASSURANCE-[A-F0-9]{20}$" },
    "documentType": { "const": "career-assurance-case" },
    "title": { "type": "string", "minLength": 1, "maxLength": 500, "pattern": ".*\\S.*" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "caseHash", "bindingHash", "recommendation", "valid", "actionable", "certified", "redactedEvidenceCount", "redactedNarrativeCount"],
      "properties": {
        "caseId": { "type": "string", "pattern": "^(ASC|CASE)-[A-Z0-9-]+$" },
        "caseHash": { "$ref": "#/definitions/hash" },
        "bindingHash": { "$ref": "#/definitions/hash" },
        "recommendation": { "enum": ["proceed", "defer", "decline"] },
        "valid": { "type": "boolean" },
        "actionable": { "type": "boolean" },
        "certified": { "type": "boolean" },
        "redactedEvidenceCount": { "type": "integer", "minimum": 0, "maximum": 500 },
        "redactedNarrativeCount": { "type": "integer", "minimum": 0, "maximum": 500 }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pageSize", "marginPoints", "bodyFontSize"],
      "properties": {
        "pageSize": { "enum": ["A4", "LETTER"] },
        "marginPoints": { "type": "integer", "minimum": 36, "maximum": 90 },
        "bodyFontSize": { "type": "number", "minimum": 9, "maximum": 14 }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/heading" },
          { "$ref": "#/definitions/paragraph" },
          { "$ref": "#/definitions/table" }
        ]
      }
    }
  },
  "definitions": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "nodeId": { "type": "string", "pattern": "^NODE-ASSURANCE-[A-Z0-9-]+$" },
    "heading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "type", "level", "text"],
      "properties": {
        "nodeId": { "$ref": "#/definitions/nodeId" },
        "type": { "const": "heading" },
        "level": { "type": "integer", "minimum": 1, "maximum": 3 },
        "text": { "type": "string", "minLength": 1, "maxLength": 500, "pattern": ".*\\S.*" }
      }
    },
    "paragraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "type", "text"],
      "properties": {
        "nodeId": { "$ref": "#/definitions/nodeId" },
        "type": { "const": "paragraph" },
        "text": { "type": "string", "minLength": 1, "maxLength": 8000, "pattern": ".*\\S.*" }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "type", "columns", "rows"],
      "properties": {
        "nodeId": { "$ref": "#/definitions/nodeId" },
        "type": { "const": "table" },
        "columns": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        },
        "rows": {
          "type": "array",
          "maxItems": 500,
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": { "type": "string", "maxLength": 4000 }
          }
        }
      }
    }
  }
}
