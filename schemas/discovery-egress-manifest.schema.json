{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/discovery-egress-manifest.schema.json",
  "title": "EgressManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestId",
    "providerId",
    "version",
    "allowedHosts",
    "allowedPorts",
    "allowedPathPrefixes",
    "allowedMethods",
    "allowedRequestHeaders",
    "redirectPolicy",
    "responsePolicy",
    "ratePolicy",
    "cachePolicy",
    "grantPolicy"
  ],
  "properties": {
    "manifestId": { "type": "string", "pattern": "^egress:[a-z][a-z0-9-]{1,63}$" },
    "providerId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "allowedHosts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3, "maxLength": 253 }
    },
    "allowedPorts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 1, "maximum": 65535 }
    },
    "allowedPathPrefixes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^/[^?#\\\\]*$" }
    },
    "allowedMethods": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": { "enum": ["GET", "HEAD"] }
    },
    "allowedRequestHeaders": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" }
    },
    "redirectPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxRedirects", "allowCrossHost"],
      "properties": {
        "maxRedirects": { "type": "integer", "minimum": 0, "maximum": 10 },
        "allowCrossHost": { "type": "boolean" }
      }
    },
    "responsePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedStatusRanges", "allowedContentTypes", "requireContentType", "maxBodyBytes", "timeoutMs"],
      "properties": {
        "allowedStatusRanges": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["min", "max"],
            "properties": {
              "min": { "type": "integer", "minimum": 100, "maximum": 599 },
              "max": { "type": "integer", "minimum": 100, "maximum": 599 }
            }
          }
        },
        "allowedContentTypes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9!#$&^_.+-]+/[a-z0-9!#$&^_.+-]+$" }
        },
        "requireContentType": { "type": "boolean" },
        "maxBodyBytes": { "type": "integer", "minimum": 1, "maximum": 67108864 },
        "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 120000 }
      }
    },
    "ratePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxRequests", "windowMs"],
      "properties": {
        "maxRequests": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "windowMs": { "type": "integer", "minimum": 1, "maximum": 86400000 }
      }
    },
    "cachePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ttlMs", "methods"],
      "properties": {
        "ttlMs": { "type": "integer", "minimum": 0, "maximum": 86400000 },
        "methods": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "enum": ["GET", "HEAD"] }
        }
      }
    },
    "grantPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxTtlMs", "maxRequests", "requireExactHosts"],
      "properties": {
        "maxTtlMs": { "type": "integer", "minimum": 1, "maximum": 604800000 },
        "maxRequests": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "requireExactHosts": { "type": "boolean" }
      }
    }
  }
}
