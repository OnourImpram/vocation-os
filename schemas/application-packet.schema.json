{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/application-packet.schema.json",
  "title": "ApplicationPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "opportunityId",
    "claims",
    "documents",
    "tosCompliant",
    "generatedAt",
    "packetHash",
    "approvalRequired"
  ],
  "properties": {
    "opportunityId": {
      "type": "string",
      "pattern": "^OPP-[A-Z0-9-]+$"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claimId",
          "text",
          "sourceClaimTextHash",
          "evidenceStatus",
          "sourcePointer",
          "publiclyAssertable"
        ],
        "properties": {
          "claimId": {
            "type": "string",
            "pattern": "^CLM-[A-Z0-9-]+$"
          },
          "text": {
            "type": "string",
            "minLength": 3
          },
          "sourceClaimTextHash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "evidenceStatus": {
            "$ref": "https://vocation-os.dev/schemas/evidence-status.schema.json"
          },
          "sourcePointer": {
            "type": "string",
            "minLength": 1
          },
          "publiclyAssertable": {
            "type": "boolean"
          }
        }
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["cv", "cover-letter", "outreach", "other"]
          },
          "path": {
            "type": "string"
          },
          "contentHash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "tosCompliant": {
      "type": "boolean"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "packetHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "approvalRequired": {
      "type": "boolean"
    }
  }
}
