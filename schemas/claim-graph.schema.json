{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/claim-graph.schema.json",
  "title": "ClaimGraph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profileId",
    "profileScope",
    "generatedAt",
    "graphVersion",
    "claims",
    "validationSummary"
  ],
  "properties": {
    "profileId": {
      "type": "string",
      "pattern": "^(DEMO|LOCAL|PRIVATE)-[A-Z0-9-]+$"
    },
    "profileScope": {
      "type": "string",
      "enum": ["synthetic", "local-private"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "graphVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://vocation-os.dev/schemas/claim.schema.json"
      }
    },
    "validationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verifiedClaims", "unverifiedClaims", "privateClaims"],
      "properties": {
        "verifiedClaims": {
          "type": "integer",
          "minimum": 0
        },
        "unverifiedClaims": {
          "type": "integer",
          "minimum": 0
        },
        "privateClaims": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
