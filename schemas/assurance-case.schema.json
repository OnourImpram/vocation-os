{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/assurance-case.schema.json",
  "title": "CareerAssuranceCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "caseId",
    "createdAt",
    "decision",
    "evidence",
    "uncertainties",
    "defeaters",
    "policies",
    "approvals",
    "receipts",
    "versions",
    "generator",
    "bindingHash",
    "caseHash",
    "certification"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "caseId": { "type": "string", "pattern": "^(ASC|CASE)-[A-Z0-9-]+$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "decision": { "$ref": "#/definitions/decision" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": { "$ref": "#/definitions/evidence" }
    },
    "uncertainties": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/definitions/uncertainty" }
    },
    "defeaters": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/definitions/defeater" }
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": { "$ref": "#/definitions/policy" }
    },
    "approvals": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/definitions/approval" }
    },
    "receipts": {
      "type": "array",
      "maxItems": 500,
      "items": { "$ref": "#/definitions/receipt" }
    },
    "versions": { "$ref": "#/definitions/versions" },
    "generator": { "$ref": "#/definitions/generator" },
    "bindingHash": { "$ref": "#/definitions/hash" },
    "caseHash": { "$ref": "#/definitions/hash" },
    "certification": {
      "oneOf": [
        { "$ref": "#/definitions/certification" },
        { "type": "null" }
      ]
    }
  },
  "definitions": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "boundedId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionId", "routeId", "recommendation", "statement", "reversibility", "highStakes", "disclosure"],
      "properties": {
        "decisionId": { "type": "string", "pattern": "^(DEC|DECISION)-[A-Z0-9-]+$" },
        "routeId": { "$ref": "#/definitions/boundedId" },
        "recommendation": { "enum": ["proceed", "defer", "decline"] },
        "statement": { "type": "string", "minLength": 1, "maxLength": 4000, "pattern": ".*\\S.*" },
        "reversibility": { "enum": ["R0", "R1", "R2", "R3", "R4"] },
        "highStakes": { "type": "boolean" },
        "disclosure": { "enum": ["private", "public"] }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceId", "claimId", "claimHash", "sourceId", "sourceHash", "observedAt", "freshUntil", "disclosure"],
      "properties": {
        "evidenceId": { "type": "string", "pattern": "^(EVD|EVIDENCE)-[A-Z0-9-]+$" },
        "claimId": { "type": "string", "pattern": "^(CLM|CLAIM)-[A-Z0-9-]+$" },
        "claimHash": { "$ref": "#/definitions/hash" },
        "sourceId": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^\\S+$" },
        "sourceHash": { "$ref": "#/definitions/hash" },
        "observedAt": { "type": "string", "format": "date-time" },
        "freshUntil": { "type": "string", "format": "date-time" },
        "disclosure": { "enum": ["private", "public"] }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uncertaintyId", "description", "material", "status", "evidenceIds", "disclosure"],
      "properties": {
        "uncertaintyId": { "type": "string", "pattern": "^(UNC|UNCERTAINTY)-[A-Z0-9-]+$" },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000, "pattern": ".*\\S.*" },
        "material": { "type": "boolean" },
        "status": { "enum": ["unresolved", "resolved"] },
        "evidenceIds": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(EVD|EVIDENCE)-[A-Z0-9-]+$" }
        },
        "disclosure": { "enum": ["private", "public"] }
      }
    },
    "defeater": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defeaterId", "kind", "description", "status", "evidenceIds", "resolution", "disclosure"],
      "properties": {
        "defeaterId": { "type": "string", "pattern": "^(DFT|DEFEATER)-[A-Z0-9-]+$" },
        "kind": { "enum": ["hard", "soft"] },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000, "pattern": ".*\\S.*" },
        "status": { "enum": ["unresolved", "resolved", "accepted"] },
        "evidenceIds": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(EVD|EVIDENCE)-[A-Z0-9-]+$" }
        },
        "resolution": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 2000, "pattern": ".*\\S.*" },
            { "type": "null" }
          ]
        },
        "disclosure": { "enum": ["private", "public"] }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyId", "policyVersionHash", "outcome", "rationale", "evaluatedAt", "disclosure"],
      "properties": {
        "policyId": { "$ref": "#/definitions/boundedId" },
        "policyVersionHash": { "$ref": "#/definitions/hash" },
        "outcome": { "enum": ["allow", "deny", "manual-review"] },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 4000, "pattern": ".*\\S.*" },
        "evaluatedAt": { "type": "string", "format": "date-time" },
        "disclosure": { "enum": ["private", "public"] }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approvalId", "approverPrincipalId", "approvedAt", "expiresAt", "scopeHash", "acknowledgedSoftDefeaterIds", "signatureReceiptHash"],
      "properties": {
        "approvalId": { "type": "string", "pattern": "^(APR|APPROVAL)-[A-Z0-9-]+$" },
        "approverPrincipalId": { "$ref": "#/definitions/boundedId" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "scopeHash": { "$ref": "#/definitions/hash" },
        "acknowledgedSoftDefeaterIds": {
          "type": "array",
          "maxItems": 200,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(DFT|DEFEATER)-[A-Z0-9-]+$" }
        },
        "signatureReceiptHash": { "$ref": "#/definitions/hash" }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receiptId", "operation", "outcome", "occurredAt", "requestHash", "resultHash", "eventHash", "scopeHash", "approvalId"],
      "properties": {
        "receiptId": { "type": "string", "pattern": "^(RCP|RECEIPT)-[A-Z0-9-]+$" },
        "operation": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
        "outcome": { "enum": ["succeeded", "failed", "blocked"] },
        "occurredAt": { "type": "string", "format": "date-time" },
        "requestHash": { "$ref": "#/definitions/hash" },
        "resultHash": { "$ref": "#/definitions/hash" },
        "eventHash": { "$ref": "#/definitions/hash" },
        "scopeHash": { "$ref": "#/definitions/hash" },
        "approvalId": {
          "oneOf": [
            { "type": "string", "pattern": "^(APR|APPROVAL)-[A-Z0-9-]+$" },
            { "type": "null" }
          ]
        }
      }
    },
    "versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelHash", "policySetHash", "taxonomyHash", "dataSnapshotHash", "generatorBuildHash"],
      "properties": {
        "modelHash": { "$ref": "#/definitions/hash" },
        "policySetHash": { "$ref": "#/definitions/hash" },
        "taxonomyHash": { "$ref": "#/definitions/hash" },
        "dataSnapshotHash": { "$ref": "#/definitions/hash" },
        "generatorBuildHash": { "$ref": "#/definitions/hash" }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principalId", "componentId", "generatedAt"],
      "properties": {
        "principalId": { "$ref": "#/definitions/boundedId" },
        "componentId": { "$ref": "#/definitions/boundedId" },
        "generatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["certifierPrincipalId", "certifierComponentId", "certifiedAt", "certifiedCaseHash", "signatureReceiptHash"],
      "properties": {
        "certifierPrincipalId": { "$ref": "#/definitions/boundedId" },
        "certifierComponentId": { "$ref": "#/definitions/boundedId" },
        "certifiedAt": { "type": "string", "format": "date-time" },
        "certifiedCaseHash": { "$ref": "#/definitions/hash" },
        "signatureReceiptHash": { "$ref": "#/definitions/hash" }
      }
    }
  }
}
