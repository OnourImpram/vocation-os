{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/discovery-opportunity-truth-record.schema.json",
  "title": "OpportunityTruthRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "truthRecordId",
    "opportunityKey",
    "assessedAt",
    "mandatoryFields",
    "fields",
    "disposition",
    "blockers"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "truthRecordId": { "type": "string", "pattern": "^TRUTH-[A-F0-9]{32}$" },
    "opportunityKey": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,255}$" },
    "assessedAt": { "type": "string", "format": "date-time" },
    "mandatoryFields": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/fieldName" }
    },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "salary",
        "remoteConditions",
        "workAuthorization",
        "licensing",
        "location",
        "deadline"
      ],
      "properties": {
        "salary": { "$ref": "#/definitions/fieldTruth" },
        "remoteConditions": { "$ref": "#/definitions/fieldTruth" },
        "workAuthorization": { "$ref": "#/definitions/fieldTruth" },
        "licensing": { "$ref": "#/definitions/fieldTruth" },
        "location": { "$ref": "#/definitions/fieldTruth" },
        "deadline": { "$ref": "#/definitions/fieldTruth" }
      }
    },
    "disposition": { "enum": ["actionable", "blocked"] },
    "blockers": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "code"],
        "properties": {
          "field": { "$ref": "#/definitions/fieldName" },
          "code": { "enum": ["conflicting-evidence", "mandatory-unresolved", "mandatory-stale"] }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "required": ["disposition"], "properties": { "disposition": { "const": "actionable" } } },
      "then": { "properties": { "blockers": { "type": "array", "maxItems": 0 } } },
      "else": { "properties": { "blockers": { "type": "array", "minItems": 1 } } }
    }
  ],
  "definitions": {
    "fieldName": {
      "enum": ["salary", "remoteConditions", "workAuthorization", "licensing", "location", "deadline"]
    },
    "truthState": {
      "enum": ["observed", "inferred", "consistent", "conflicting", "stale", "unresolved"]
    },
    "jsonValue": {
      "oneOf": [
        { "type": "null" },
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "array", "items": { "$ref": "#/definitions/jsonValue" } },
        { "type": "object", "additionalProperties": { "$ref": "#/definitions/jsonValue" } }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observationId", "pointer", "observedAt"],
      "properties": {
        "observationId": { "type": "string", "pattern": "^OBS-[A-F0-9]{32}$" },
        "pointer": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "observedAt": { "type": "string", "format": "date-time" }
      }
    },
    "recencyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyId", "maxAgeMs", "maxFutureSkewMs", "onExpiry"],
      "properties": {
        "policyId": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{1,127}$" },
        "maxAgeMs": { "type": "integer", "minimum": 1, "maximum": 31536000000 },
        "maxFutureSkewMs": { "type": "integer", "minimum": 0, "maximum": 86400000 },
        "onExpiry": { "const": "stale" }
      }
    },
    "fieldTruth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "value", "evidence", "observedAt", "recencyPolicy", "rationale"],
      "properties": {
        "state": { "$ref": "#/definitions/truthState" },
        "value": { "$ref": "#/definitions/jsonValue" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/evidence" }
        },
        "observedAt": { "type": "string", "format": "date-time" },
        "recencyPolicy": { "$ref": "#/definitions/recencyPolicy" },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 2000 }
      },
      "allOf": [
        {
          "if": {
            "required": ["state"],
            "properties": { "state": { "enum": ["conflicting", "unresolved"] } }
          },
          "then": { "properties": { "value": { "type": "null" } } }
        },
        {
          "if": {
            "required": ["state"],
            "properties": { "state": { "enum": ["observed", "inferred", "consistent"] } }
          },
          "then": { "properties": { "value": { "not": { "type": "null" } } } }
        },
        {
          "if": {
            "required": ["state"],
            "properties": { "state": { "enum": ["consistent", "conflicting"] } }
          },
          "then": { "properties": { "evidence": { "type": "array", "minItems": 2 } } }
        }
      ]
    }
  }
}
