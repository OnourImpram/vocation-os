{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/credential-passport.schema.json",
  "title": "CredentialPassportEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "passportEntryId",
    "importedAt",
    "original",
    "envelopeFormat",
    "canonicalCredentialHash",
    "credential",
    "summary",
    "verification",
    "mappings"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "passportEntryId": {
      "type": "string",
      "pattern": "^CREDENTIAL-[0-9A-F]{64}$"
    },
    "importedAt": { "$ref": "#/definitions/dateTime" },
    "original": { "$ref": "#/definitions/original" },
    "envelopeFormat": { "enum": ["json", "json-ld", "compact-jws"] },
    "canonicalCredentialHash": { "$ref": "#/definitions/hash" },
    "credential": { "type": "object" },
    "summary": { "$ref": "#/definitions/summary" },
    "verification": { "$ref": "#/definitions/verification" },
    "mappings": {
      "type": "array",
      "items": { "$ref": "#/definitions/mapping" }
    }
  },
  "definitions": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "not": { "enum": ["__proto__", "constructor", "prototype"] }
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "nullableString": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1, "maxLength": 4096 }
      ]
    },
    "original": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hash", "byteLength", "format", "mediaType"],
      "properties": {
        "hash": { "$ref": "#/definitions/hash" },
        "byteLength": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "format": { "enum": ["json", "json-ld", "compact-jws", "baked-png", "baked-svg"] },
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 200 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credentialId", "issuerId", "subjectId", "achievementId", "achievementName", "validFrom", "validUntil"],
      "properties": {
        "credentialId": { "$ref": "#/definitions/nullableString" },
        "issuerId": { "$ref": "#/definitions/nullableString" },
        "subjectId": { "$ref": "#/definitions/nullableString" },
        "achievementId": { "$ref": "#/definitions/nullableString" },
        "achievementName": { "$ref": "#/definitions/nullableString" },
        "validFrom": { "$ref": "#/definitions/nullableString" },
        "validUntil": { "$ref": "#/definitions/nullableString" }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "code", "checkedAt", "details"],
      "properties": {
        "status": { "enum": ["pass", "fail", "not-checked", "not-applicable"] },
        "code": { "type": "string", "minLength": 1, "maxLength": 200 },
        "checkedAt": { "$ref": "#/definitions/dateTime" },
        "details": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "signature", "issuer", "subject", "time", "revocation", "refresh", "overall", "eligibleForMapping"],
      "properties": {
        "schema": { "$ref": "#/definitions/check" },
        "signature": { "$ref": "#/definitions/check" },
        "issuer": { "$ref": "#/definitions/check" },
        "subject": { "$ref": "#/definitions/check" },
        "time": { "$ref": "#/definitions/check" },
        "revocation": { "$ref": "#/definitions/check" },
        "refresh": { "$ref": "#/definitions/check" },
        "overall": { "enum": ["verified", "rejected", "incomplete"] },
        "eligibleForMapping": { "type": "boolean" }
      }
    },
    "mappingApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approvalId", "approverPrincipalId", "approvedAt", "expiresAt", "mappingHash", "allowPublic", "allowAutoApply", "signatureReceiptHash"],
      "properties": {
        "approvalId": { "$ref": "#/definitions/identifier" },
        "approverPrincipalId": { "$ref": "#/definitions/identifier" },
        "approvedAt": { "$ref": "#/definitions/dateTime" },
        "expiresAt": { "$ref": "#/definitions/dateTime" },
        "mappingHash": { "$ref": "#/definitions/hash" },
        "allowPublic": { "type": "boolean" },
        "allowAutoApply": { "type": "boolean" },
        "signatureReceiptHash": { "$ref": "#/definitions/hash" }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mappingId",
        "credentialId",
        "credentialHash",
        "claimType",
        "claimText",
        "sourcePointer",
        "requestedPublic",
        "requestedAutoApply",
        "publiclyAssertable",
        "allowedInAutoApply",
        "status",
        "mappingHash",
        "approval"
      ],
      "properties": {
        "mappingId": { "$ref": "#/definitions/identifier" },
        "credentialId": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "credentialHash": { "$ref": "#/definitions/hash" },
        "claimType": { "enum": ["degree", "license", "publication", "affiliation", "grant", "employment", "credential", "award", "skill", "project", "other"] },
        "claimText": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "sourcePointer": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "requestedPublic": { "type": "boolean" },
        "requestedAutoApply": { "type": "boolean" },
        "publiclyAssertable": { "type": "boolean" },
        "allowedInAutoApply": { "type": "boolean" },
        "status": { "enum": ["pending", "approved"] },
        "mappingHash": { "$ref": "#/definitions/hash" },
        "approval": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/mappingApproval" }
          ]
        }
      }
    }
  }
}
