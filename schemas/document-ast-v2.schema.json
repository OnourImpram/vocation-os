{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/document-ast-v2.schema.json",
  "title": "DocumentAstV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "documentId", "kind", "profileId", "opportunityId", "titleKey", "locale", "generatedAt", "layout", "sections"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "documentId": { "type": "string", "pattern": "^DOC-[A-Z0-9-]+$" },
    "kind": { "enum": ["cv", "cover-letter", "outreach", "interview-story", "public-profile"] },
    "profileId": { "type": "string", "pattern": "^(DEMO|LOCAL|PRIVATE)-[A-Z0-9-]+$" },
    "opportunityId": { "oneOf": [{ "type": "string", "pattern": "^OPP-[A-Z0-9-]+$" }, { "type": "null" }] },
    "titleKey": { "enum": ["cv", "cover-letter", "outreach", "interview-story", "public-profile"] },
    "locale": { "enum": ["en", "en-US", "en-GB", "tr", "tr-TR"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pageSize", "marginPoints", "bodyFontSize"],
      "properties": {
        "pageSize": { "enum": ["A4", "LETTER"] },
        "marginPoints": { "type": "integer", "minimum": 36, "maximum": 90 },
        "bodyFontSize": { "type": "number", "minimum": 9, "maximum": 14 }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sectionId", "labelKey", "nodes"],
        "properties": {
          "sectionId": { "type": "string", "pattern": "^SEC-[A-Z0-9-]+$" },
          "labelKey": {
            "enum": ["summary", "experience", "education", "skills", "projects", "publications", "credentials", "selected-evidence", "contact", "motivation", "fit", "closing"]
          },
          "nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["nodeId", "type", "level", "textKey", "claimIds"],
                  "properties": {
                    "nodeId": { "type": "string", "pattern": "^NODE-[A-Z0-9-]+$" },
                    "type": { "const": "heading" },
                    "level": { "type": "integer", "minimum": 1, "maximum": 3 },
                    "textKey": {
                      "enum": ["summary", "experience", "education", "skills", "projects", "publications", "credentials", "selected-evidence", "contact", "motivation", "fit", "closing"]
                    },
                    "claimIds": { "type": "array", "maxItems": 0 }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["nodeId", "type", "bindingMode", "text", "claimIds", "textHash"],
                  "properties": {
                    "nodeId": { "type": "string", "pattern": "^NODE-[A-Z0-9-]+$" },
                    "type": { "enum": ["sentence", "bullet"] },
                    "bindingMode": { "const": "verbatim-claim" },
                    "text": { "type": "string", "minLength": 1, "maxLength": 2000, "pattern": ".*\\S.*" },
                    "claimIds": {
                      "type": "array",
                      "minItems": 1,
                      "maxItems": 1,
                      "items": { "type": "string", "pattern": "^CLM-[A-Z0-9-]+$" }
                    },
                    "textHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
