{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vocation-os.dev/schemas/answer-memory-record.schema.json",
  "title": "AnswerMemoryRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["answerId", "questionType", "normalizedPrompt", "promptHash", "answerText", "answerHash", "evidenceStatus", "sourcePointer", "scope", "roleFamily", "opportunityId", "sensitivity", "reusable", "requiresPerOpportunityConfirmation", "allowedModes", "expiresAt", "status", "createdAt", "updatedAt"],
  "properties": {
    "answerId": { "type": "string", "pattern": "^ANS-[A-Z0-9-]+$" },
    "questionType": { "enum": ["identity", "contact", "work-authorization", "visa-sponsorship", "relocation", "compensation", "license", "education", "experience", "skill", "eeo-demographic", "custom"] },
    "normalizedPrompt": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "promptHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "answerText": { "type": "string", "minLength": 1, "maxLength": 5000 },
    "answerHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "evidenceStatus": { "enum": ["verified", "operator_supplied"] },
    "sourcePointer": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "scope": { "enum": ["global", "role-family", "opportunity"] },
    "roleFamily": { "oneOf": [{ "type": "string", "minLength": 1, "maxLength": 160 }, { "type": "null" }] },
    "opportunityId": { "oneOf": [{ "type": "string", "pattern": "^OPP-[A-Z0-9-]+$" }, { "type": "null" }] },
    "sensitivity": { "enum": ["standard", "sensitive", "restricted"] },
    "reusable": { "type": "boolean" },
    "requiresPerOpportunityConfirmation": { "type": "boolean" },
    "allowedModes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["assist", "supervised", "approved-auto"] } },
    "expiresAt": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
    "status": { "enum": ["active", "retired"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
